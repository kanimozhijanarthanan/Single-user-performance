# PulseLab — optional LLM (Azure OpenAI) configuration.
# Copy this file to ".env" (same folder) and fill in your values.
# With no .env, PulseLab works fully — it just uses rule-based insights instead
# of LLM-written analysis, and the "Generate with LLM" flow option is disabled.
#
# The key is read ONLY here on the server. It is never sent to the browser,
# never logged, and never returned by any API. Keep .env out of version control.

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-rotated-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-12-01-preview
